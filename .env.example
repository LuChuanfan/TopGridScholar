## TopGridScholar environment variables
#
# Optional: override where runtime data is stored.
# Default is the project directory (next to config.py).
# PAPERDOWNLOADER_BASE_DIR=E:/PaperDownloader
#
# Recommended: Semantic Scholar API key (for CCF-A/B search).
# Get one at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

